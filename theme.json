            "max": "4.5rem"
          }
        }
      ]
    },
    "spacing": {
      "defaultSpacingSizes": false,
      "spacingSizes": [
        {
          "name": "XXS",
          "slug": "5",
          "size": "clamp(0.250rem, calc(0.227rem + 0.006vw), 0.312rem)"
        },
        {
          "name": "XS",
          "slug": "10",
          "size": "clamp(0.500rem, calc(0.454rem + 0.012vw), 0.625rem)"
        },
        {
          "name": "S",
          "slug": "20",
          "size": "clamp(0.875rem, calc(0.736rem + 0.036vw), 1.250rem)"
        },
        {
          "name": "M",
          "slug": "30",
          "size": "clamp(1.250rem, calc(1.018rem + 0.060vw), 1.875rem)"
        },
        {
          "name": "L",
          "slug": "40",
          "size": "clamp(1.625rem, calc(1.300rem + 0.083vw), 2.500rem)"
        },
        {
          "name": "XL",
          "slug": "50",
          "size": "clamp(2.062rem, calc(1.668rem + 0.101vw), 3.125rem)"
        },
        {
          "name": "XXL",
          "slug": "60",
          "size": "clamp(2.312rem, calc(1.779rem + 0.137vw), 3.750rem)"
        },
        {
          "name": "XXXL",
          "slug": "70",
          "size": "clamp(3.125rem, calc(2.875rem + 1.250vw), 4.375rem)"
        },
        {
          "name": "XXXXL",
          "slug": "80",
          "size": "clamp(4.000rem, calc(3.600rem + 2.000vw), 6.000rem)"
        },
        {
          "name": "Gigantic",
          "slug": "90",
          "size": "clamp(5.000rem, calc(4.555rem + 2.225vw), 7.225rem)"
        },
        {
          "name": "Colossal",
          "slug": "100",
          "size": "clamp(6.500rem, calc(6.150rem + 1.750vw), 8.250rem)"
        }
      ],
      "units": ["px", "em", "rem", "vh", "vw", "%"],
      "blockGap": true,
      "padding": true,
      "margin": true
    },
    "border": {
      "radius": true,
      "radiusSizes": [
        {
          "name": "tiny",
          "slug": "100",
          "size": "4px"
        },
        {
          "name": "small",
          "slug": "300",
          "size": "8px"
        },
        {
          "name": "medium",
          "slug": "500",
          "size": "16px"
        },
        {
          "name": "large",
          "slug": "700",
          "size": "24px"
        },
        {
          "name": "full",
          "slug": "900",
          "size": "9999px"
        }
      ]
    },
    "shadow": {
      "defaultPresets": false,
      "presets": [
        {
          "name": "None",
          "slug": "100",
          "shadow": "none"
        },
        {
          "name": "Subtle",
          "slug": "200",
          "shadow": "0 1px 2px rgba(35, 31, 32, 0.10)"
        },
        {
          "name": "Base",
          "slug": "300",
          "shadow": "0 8px 24px rgba(35, 31, 32, 0.12)"
        },
        {
          "name": "Lifted",
          "slug": "500",
          "shadow": "0 16px 40px rgba(35, 31, 32, 0.16)"
        },
        {
          "name": "Overlay",
          "slug": "600",
          "shadow": "0 24px 70px rgba(35, 31, 32, 0.20)"
        }
      ]
    },
    "custom": {
      "color": {
        "surface": {
          "default": "var(--wp--preset--color--base)",
          "soft": "var(--wp--preset--color--neutral-100)",
          "dark": "var(--wp--preset--color--contrast)"
        },
        "text": {
          "default": "var(--wp--preset--color--contrast)",
          "muted": "var(--wp--preset--color--neutral-700)",
          "inverse": "var(--wp--preset--color--base)"
        },
        "action": {
          "default": "var(--wp--preset--color--primary-500)",
          "hover": "var(--wp--preset--color--cta-500)"
        },
        "border": {
          "light": "var(--wp--preset--color--neutral-200)",
          "dark": "var(--wp--preset--color--neutral-600)"
        }
      },
      "border": {
        "width": {
          "thin": "1px",
          "thick": "2px",
          "heavy": "4px",
          "extra-heavy": "8px"
        }
      },
      "typography": {
        "letter-spacing": {
          "tighter": "-0.05em",
          "tight": "-0.025em",
          "normal": "0",
          "wide": "0.025em",
          "wider": "0.05em",
          "widest": "0.1em"
        },
        "font-weight": {
          "thin": "100",
          "extralight": "200",
          "light": "300",
          "normal": "400",
          "medium": "500",
          "semibold": "600",
          "bold": "700",
          "extrabold": "800",
          "black": "900"
        },
        "line-height": {
          "none": "1",
          "tight": "1.1",
          "heading": "1.25",
          "snug": "1.35",
          "normal": "1.5",
          "relaxed": "1.625"
        }
      },
      "tour-operator": {
        "meta-panel-gap": "0.5rem",
        "meta-panel-padding-x": "0.75rem",
        "meta-panel-padding-y": "0.5rem"
      }
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--heading)",
      "fontSize": "var(--wp--preset--font-size--300)",
      "fontWeight": "var(--wp--custom--typography--font-weight--normal)",
      "lineHeight": "var(--wp--custom--typography--line-height--normal)"
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--30)",
      "padding": {
        "top": "0",
        "right": "var(--wp--preset--spacing--30)",
        "bottom": "0",
        "left": "var(--wp--preset--spacing--30)"
      }
    },
    "elements": {
      "button": {
        "border": {
          "radius": "0px"
        },
        "color": {
          "background": "var:preset|color|cta-500",
          "text": "var:preset|color|base"
        },
        "typography": {
          "fontSize": "var:preset|font-size|300",
		  "fontWeight": "var(--wp--custom--typography--font-weight--light)",
          "letterSpacing": "var:custom|typography|letter-spacing|wide",
          "textTransform": "uppercase"
        },
        "spacing": {
          "padding": {
            "left": "var:preset|spacing|40",
            "right": "var:preset|spacing|40",
            "top": "var:preset|spacing|20",
            "bottom": "var:preset|spacing|20"
          }
        },
        "css": "&{transition: background-color 200ms ease} &:hover{background-color: var(--wp--preset--color--accent-500); color: var(--wp--preset--color--base);} &:focus-visible{outline: 2px solid var(--wp--preset--color--cta-500); outline-offset: 2px;} &:active{background-color: var(--wp--preset--color--accent-500); color: var(--wp--preset--color--base);}"
      },
      "heading": {
        "color": {
          "text": "var:preset|color|contrast"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontWeight": "var:custom|typography|font-weight|normal"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var:preset|font-size|800",
          "lineHeight": "var:custom|typography|line-height|snug"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var:preset|font-size|600",
          "lineHeight": "var:custom|typography|line-height|snug"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var:preset|font-size|400",
          "lineHeight": "var:custom|typography|line-height|snug"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var:preset|font-size|300",
          "lineHeight": "var:custom|typography|line-height|normal"
        }
      },
      "h5": {
        "typography": {
          "fontSize": "var:preset|font-size|200",
		  "lineHeight": "var:custom|typography|line-height|normal"
        }
      },
      "h6": {
        "typography": {
          "fontSize": "var:preset|font-size|200",
		  "lineHeight": "var:custom|typography|line-height|normal",
		  "textTransform": "uppercase"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|contrast"
        },
		"typography": {
          "textDecoration": "none"
        },
        ":hover": {
          "color": {
            "text": "var:preset|color|cta-500"
          },
          "typography": {
            "textDecoration": "none"
          }
        }
      },
      "paragraph": {
        "color": {
          "text": "var:preset|color|contrast"
        },
        "typography": {
          "fontFamily": "var:preset|font-family|heading",
          "fontSize": "var:preset|font-size|200",
          "lineHeight": "24px"
        }
      }
    },
    "blocks": {
      "core/button": {
        "variations": {
          "outline": {
            "border": {
              "width": "1px",
              "color": "var:preset|color|base",
              "style": "solid"
            },
            "color": {
              "background": "color-mix(in srgb, var(--wp--preset--color--contrast) 40%, transparent)",
              "text": "var:preset|color|base"
            },
            "typography": {
              "fontSize": "var:preset|font-size|200",
              "fontWeight": "var:custom|typography|font-weight|normal",
              "letterSpacing": "var:custom|typography|letter-spacing|wide",
              "textTransform": "uppercase"
            },
            "spacing": {
              "padding": {
                "left": "var(--wp--preset--spacing--40)",
                "right": "var(--wp--preset--spacing--40)",
                "top": "var(--wp--preset--spacing--20)",
                "bottom": "var(--wp--preset--spacing--20)"
              }
            },
            "css": "&{transition: background-color 200ms ease; color: var(--wp--preset--color--base);} & svg{color: currentColor; fill: currentColor;} &:hover{background-color: color-mix(in srgb, var(--wp--preset--color--contrast) 60%, transparent);}"
          }
        }
      },
      "core/template-part": {
        "spacing": {
          "margin": {
            "top": "0"
          }
        }
      },
      "core/query-pagination": {
        "spacing": {
          "blockGap": "var(--wp--preset--spacing--10)"
        },
        "elements": {
          "link": {
            "border": {
              "color": "var:preset|color|accent-500",
              "style": "solid",
              "width": "2px",
              "radius": "var:preset|border-radius|100"
            },
            "color": {
              "background": "var:preset|color|base",
              "text": "var:preset|color|accent-500"
            },
            ":hover": {
              "color": {
                "background": "var:preset|color|accent-500",
                "text": "var:preset|color|base"
              }
            },
            "css": "&{transition: background-color 200ms ease, color 200ms ease, border-color 200ms ease;}"
          }
        }
      },
      "core/query-pagination-next": {
        "spacing": {
          "padding": {
            "top": "6px",
            "right": "16px",
            "bottom": "6px",
            "left": "16px"
          }
        }
      },
	 "core/query-pagination-previous": {
        "spacing": {
          "padding": {
            "top": "6px",
            "right": "16px",
            "bottom": "6px",
            "left": "16px"
          }
        }
      },
      "core/query-pagination-numbers": {
        "spacing": {
          "padding": {
            "top": "6px",
            "right": "16px",
            "bottom": "6px",
            "left": "16px"
          }
        },
        "css": "& .page-numbers { display: inline-flex; align-items: center; justify-content: center; min-width: 2rem; min-height: 2.1rem; padding: 0.25rem 0.5rem; line-height: 1.4; text-decoration: none; border: 2px solid var(--wp--preset--color--accent-500); border-radius: var(--wp--preset--border-radius--100); background-color: var(--wp--preset--color--base); color: var(--wp--preset--color--accent-500); box-shadow: none; transition: background-color 200ms ease, color 200ms ease, border-color 200ms ease; } & .page-numbers:hover { background-color: var(--wp--preset--color--accent-500); color: var(--wp--preset--color--base); } & .page-numbers.current { background-color: var(--wp--preset--color--accent-500); color: var(--wp--preset--color--base); border-color: var(--wp--preset--color--accent-500); } & .page-numbers.dots { min-width: auto; min-height: auto; padding: 0; border: 0; background: transparent; color: var(--wp--preset--color--contrast); }"
      },
      "outermost/icon-block": {
        "color": {
          "text": "var:preset|color|primary-500"
        },
        "border": {
          "radius": "var:preset|border-radius|500"
        },
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|primary-500"
            },
            ":hover": {
              "color": {
                "text": "var:preset|color|cta-500"
              }
            }
          }
        }
      },
      "cb/carousel": {
        "spacing": {
          "blockGap": "var:preset|spacing|20"
        },
        "color": {
          "text": "var:preset|color|contrast"
        },
        "css": "& .slick-prev, & .slick-next { color: var(--wp--preset--color--base); background: var(--wp--preset--color--primary-500); border: 1px solid var(--wp--preset--color--neutral-200); border-radius: 15px; } & .slick-prev:hover, & .slick-next:hover { color: var(--wp--preset--color--base); background: var(--wp--preset--color--cta-500); border-color: var(--wp--preset--color--cta-500); } & .slick-dots li button:before { color: var(--wp--preset--color--primary-500); opacity: 0.45; } & .slick-dots li.slick-active button:before { color: var(--wp--preset--color--primary-500); opacity: 1; }"
      },
      "cb/slide": {
        "color": {
          "text": "var:preset|color|contrast"
        }
      }
    }
  },
  "templateParts": [
    {
      "area": "header",
      "name": "header",
      "title": "Header"
    },
    {
      "area": "footer",
      "name": "footer",
      "title": "Footer"
    },
    {
      "area": "uncategorized",
      "name": "fast-facts-tour",
      "title": "Fast Facts - Tour"
    },
    {
      "area": "uncategorized",
      "name": "fast-facts-destination",
