			},
			"tour-operator": {
				"meta-panel-gap": "0.5rem",
				"meta-panel-padding-x": "0.75rem",
				"meta-panel-padding-y": "0.5rem"
			}
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--base)",
			"text": "var(--wp--preset--color--contrast)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--brand-serif)",
			"fontSize": "var(--wp--preset--font-size--200)",
			"fontWeight": "400",
			"lineHeight": "var(--wp--custom--typography--line-height--normal)"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--30)",
			"padding": {
				"top": "0",
				"right": "var(--wp--preset--spacing--30)",
				"bottom": "0",
				"left": "var(--wp--preset--spacing--30)"
			}
		},
		"elements": {
			"button": {
				"border": {
					"radius": "var:preset|border-radius|500",
					"width": "0"
				},
				"color": {
					"background": "var:preset|color|primary-500",
					"text": "var:preset|color|contrast"
				},
				"spacing": {
					"padding": {
						"top": "0.75rem",
						"right": "1.25rem",
						"bottom": "0.75rem",
						"left": "1.25rem"
					}
				},
				"typography": {
					"fontFamily": "var:preset|font-family|brand-serif",
					"fontSize": "var:preset|font-size|200",
					"fontWeight": "400",
					"letterSpacing": "var:custom|typography|letter-spacing|wide",
					"textTransform": "uppercase"
				},
				":hover": {
					"color": {
						"background": "var:preset|color|cta-500",
						"text": "var:preset|color|base"
					}
				}
			},
			"heading": {
				"color": {
					"text": "var:preset|color|contrast"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|brand-serif",
					"fontWeight": "600",
					"lineHeight": "var:custom|typography|line-height|tight"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|800",
					"lineHeight": "64px"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|600",
					"lineHeight": "48px"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|400",
					"lineHeight": "32px"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|300"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var:preset|font-size|200"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "var:preset|font-size|100"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|cta-500"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|cta-700"
					},
					"typography": {
						"textDecoration": "none"
					}
				},
				"typography": {
					"textDecoration": "none"
				}
			},
			"paragraph": {
				"color": {
					"text": "var:preset|color|contrast"
				},
				"typography": {
					"fontFamily": "var:preset|font-family|brand-serif",
					"fontSize": "var:preset|font-size|200",
					"lineHeight": "24px"
				}
			}
		},
		"blocks": {
			"core/query-pagination": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--30)"
				},
				"elements": {
					"link": {
						"border": {
							"color": "var:preset|color|primary-500",
							"style": "solid",
							"width": "2px",
							"radius": "8px"
						},
						"color": {
							"background": "var:preset|color|base",
							"text": "var:preset|color|primary-500"
						},
						":hover": {
							"color": {
								"background": "var:preset|color|primary-500",
								"text": "var:preset|color|base"
							}
						},
						"css": "&{transition: background-color 200ms ease, color 200ms ease, border-color 200ms ease;}"
					}
				}
			},
			"core/query-pagination-next": {
				"spacing": {
					"padding": {
						"top": "8px",
						"right": "24px",
						"bottom": "8px",
						"left": "24px"
					}
				}
			},
			"core/query-pagination-numbers": {
				"spacing": {
					"padding": {
						"top": "8px",
						"right": "10px",
						"bottom": "8px",
						"left": "10px"
					}
				},
				"css": "& .page-numbers.current { display: inline-flex; align-items: center; justify-content: center; padding-left: 16px !important; padding-right: 16px !important; padding-top: 8px !important; padding-bottom: 8px !important; line-height: 1.4; background-color: var(--wp--preset--color--primary-500); color: var(--wp--preset--color--base); border: 2px solid var(--wp--preset--color--primary-500); border-radius: 8px; box-shadow: none; }"
			},
			"core/query-pagination-previous": {
				"spacing": {
					"padding": {
						"top": "8px",
						"right": "24px",
						"bottom": "8px",
						"left": "24px"
					}
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|neutral-900"
						}
					}
				}
			},
			"outermost/icon-block": {
				"color": {
					"text": "var:preset|color|primary-500"
				},
				"border": {
					"radius": "var:preset|border-radius|500"
				},
				"spacing": {
					"padding": {
						"top": "var:preset|spacing|20",
						"right": "var:preset|spacing|20",
						"bottom": "var:preset|spacing|20",
						"left": "var:preset|spacing|20"
					}
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|primary-500"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|cta-500"
							}
						}
					}
				}
			},
			"cb/carousel": {
				"spacing": {
					"blockGap": "var:preset|spacing|20"
				},
				"color": {
					"text": "var:preset|color|contrast"
				},
				"css": "& .slick-prev, & .slick-next { color: var(--wp--preset--color--contrast); background: var(--wp--preset--color--primary-500); border: 1px solid var(--wp--preset--color--neutral-200); border-radius: 15px; } & .slick-prev:hover, & .slick-next:hover { color: var(--wp--preset--color--base); background: var(--wp--preset--color--cta-500); border-color: var(--wp--preset--color--cta-500); } & .slick-dots li button:before { color: var(--wp--preset--color--primary-500); opacity: 0.45; } & .slick-dots li.slick-active button:before { color: var(--wp--preset--color--primary-500); opacity: 1; }"
			},
			"cb/slide": {
				"color": {
					"text": "var:preset|color|contrast"
				}
			},
