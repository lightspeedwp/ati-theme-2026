{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"title": "ATI Button",
	"slug": "ati-button",
	"blockTypes": [
		"core/paragraph"
	],
	"description": "ATI Button Paragraph style for inline link pills",
	"styles": {
		"spacing": {
			"padding": {
				"top": "6px",
				"bottom": "6px",
				"left": "12px",
				"right": "12px"
			}
		},
		"border": {
			"radius": "5px"
		},
		"color": {
			"background": "var(--wp--preset--color--neutral-100)",
			"text": "var(--wp--preset--color--primary-500)"
		},
		"css": "&{display:inline-flex;width:fit-content;align-items:center;line-height:1.2;} &.ati-button-links{display:flex;flex-wrap:wrap;gap:8px;padding:0;background:transparent;} &.ati-button-links a{display:inline-flex;align-items:center;padding:6px 12px;border-radius:5px;background:var(--wp--preset--color--neutral-100);color:var(--wp--preset--color--primary-500);text-decoration:none;} &.ati-button-links a:hover,&.ati-button-links a:focus-visible{text-decoration:none;background:var(--wp--preset--color--neutral-200);} &.ati-rating-stars{gap:5px;} &.ati-rating-stars .ati-rating-star{display:inline-flex;align-items:center;justify-content:center;color:var(--wp--preset--color--primary-500);line-height:1;} &.ati-rating-stars .ati-rating-star.is-empty{opacity:0.3;}"
	}
}
