{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"title": "ATI Cover Hover Zoom",
	"slug": "ati-cover-hover-zoom",
	"blockTypes": [
		"core/cover",
		"core/image"
	],
	"description": "Cover image scales slightly on hover",
	"styles": {
		"css": "&{overflow: hidden;} & .wp-block-cover__image-background{transition: transform 300ms ease;} &:hover .wp-block-cover__image-background{transform: scale(1.05);}"
	}
}
