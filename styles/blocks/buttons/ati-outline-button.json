{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"title": "ATI Outline",
	"slug": "ati-outline-button",
	"blockTypes": [
		"core/button"
	],
	"description": "ATI outline button",
	"styles": {
		"border": {
			"radius": "var:preset|border-radius|300",
			"width": "2px",
			"color": "var:preset|color|base",
			"style": "solid"
		},
		"color": {
			"background": "color-mix(in srgb, var(--wp--preset--color--contrast) 40%, transparent)",
			"text": "var:preset|color|base"
		},
		"typography": {
			"fontSize": "var:preset|font-size|200",
			"fontWeight": "600",
			"letterSpacing": "1px"
		},
		"spacing": {
			"padding": {
				"left": "calc(var(--wp--preset--spacing--30) - 2px)",
				"right": "calc(var(--wp--preset--spacing--30) - 2px)",
				"top": "calc(var(--wp--preset--spacing--20) - 2px)",
				"bottom": "calc(var(--wp--preset--spacing--20) - 2px)"
			}
		},
		"css": "&{transition: background-color 200ms ease; color: var(--wp--preset--color--base);} & svg{color: currentColor; fill: currentColor;} &:hover{background-color: color-mix(in srgb, var(--wp--preset--color--contrast) 60%, transparent);}"
	}
}
