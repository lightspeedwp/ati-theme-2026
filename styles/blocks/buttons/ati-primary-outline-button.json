{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"title": "ATI Primary Outline",
	"slug": "ati-primary-outline-button",
	"blockTypes": [
		"core/button"
	],
	"description": "ATI Primary Outline button",
	"styles": {
		"border": {
			"radius": "var:preset|border-radius|300",
			"width": "2px",
			"color": "var:preset|color|primary-500",
			"style": "solid"
		},
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|primary-500"
		},
		"typography": {
			"fontSize": "var:preset|font-size|200",
			"fontWeight": "600",
			"letterSpacing": "1px"
		},
		"spacing": {
			"padding": {
				"left": "calc(var(--wp--preset--spacing--30) - 2px)",
				"right": "calc(var(--wp--preset--spacing--30) - 2px)",
				"top": "calc(var(--wp--preset--spacing--20) - 2px)",
				"bottom": "calc(var(--wp--preset--spacing--20) - 2px)"
			}
		},
		"css": "&{transition: background-color 200ms ease;} & svg{color: currentColor; fill: currentColor;} &:hover{color: var(--wp--preset--color--base); background-color: var(--wp--preset--color--primary-500);}"
	}
}
