{
  "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
  "version": 3,
  "title": "Horizontal Card Dark",
  "slug": "horizontal-card-dark",
  "blockTypes": [
    "core/group"
  ],
  "description": "Dark ATI styling for reusable horizontal cards.",
  "styles": {
    "border": {
      "radius": "var:preset|border-radius|100"
    },
    "color": {
      "background": "var:preset|color|primary-500",
      "text": "var:preset|color|base"
    },
    "shadow": "var:preset|shadow|200",
    "spacing": {
      "blockGap": "var:preset|spacing|20",
      "padding": {
        "top": "var:preset|spacing|20",
        "right": "var:preset|spacing|20",
        "bottom": "var:preset|spacing|20",
        "left": "var:preset|spacing|20"
      }
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var:preset|color|base"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|base"
        },
        ":hover": {
          "color": {
            "text": "var:preset|color|base"
          }
        }
      }
    },
    "blocks": {
      "core/post-featured-image": {
        "border": {
          "radius": "var:preset|border-radius|100"
        }
      },
      "core/post-excerpt": {
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|brand-500"
            },
            ":hover": {
              "color": {
                "text": "var:preset|color|brand-300"
              }
            }
          }
        }
      },
      "core/post-terms": {
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|brand-500"
            },
            ":hover": {
              "color": {
                "text": "var:preset|color|brand-300"
              }
            }
          }
        }
      },
      "core/paragraph": {
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|brand-500"
            },
            ":hover": {
              "color": {
                "text": "var:preset|color|brand-300"
              }
            }
          }
        }
      },
      "core/button": {
        "color": {
          "background": "transparent",
          "text": "var:preset|color|brand-500"
        },
        "shadow": "var:preset|shadow|100",
        "spacing": {
          "padding": {
            "top": "0",
            "right": "0",
            "bottom": "0",
            "left": "0"
          }
        },
        "typography": {
          "textDecoration": "none",
          "textTransform": "none"
        },
        "elements": {
          "link": {
            "color": {
              "background": "transparent",
              "text": "var:preset|color|brand-500"
            },
            ":hover": {
              "color": {
                "background": "transparent",
                "text": "var:preset|color|brand-300"
              }
            }
          }
        }
      },
      "outermost/icon-block": {
        "color": {
          "text": "var:preset|color|brand-500"
        }
      }
    },
    "css": "&{overflow:hidden;transition:box-shadow 300ms ease;} &:hover{box-shadow:var(--wp--preset--shadow--300)!important;} & .horizontal-card__body{padding-top:var(--wp--preset--spacing--20);padding-bottom:var(--wp--preset--spacing--20);} & .horizontal-card__details{border-top-style:none;border-top-width:0;border-bottom-style:none;border-bottom-width:0;padding-top:var(--wp--preset--spacing--20);padding-bottom:var(--wp--preset--spacing--0);} & .wp-block-cover,& .wp-block-post-featured-image{overflow:hidden;} & .wp-block-cover .wp-block-cover__image-background,& .wp-block-post-featured-image img{transition:transform 300ms ease;} &:hover .wp-block-cover .wp-block-cover__image-background,&:hover .wp-block-post-featured-image img{transform:scale(1.05);} & .wp-block-outermost-icon-block svg{fill:currentColor!important;} & .wp-block-button__link:focus-visible{outline:2px solid var(--wp--preset--color--brand-500);outline-offset:2px;}"
  }
}