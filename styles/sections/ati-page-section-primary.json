{
	"$schema": "https://schemas.wp.org/wp/trunk/theme.json",
	"version": 3,
	"title": "Page Section Primary",
	"slug": "ati-page-section-primary",
	"blockTypes": [
		"core/group"
	],
	"description": "Primary colour styling for ATI page sections",
	"styles": {
		"color": {
			"background": "var:preset|color|primary-500",
			"text": "var:preset|color|base"
		},
		"spacing": {
			"padding": {
				"top": "var:preset|spacing|90",
				"bottom": "var:preset|spacing|90"
			},
			"margin": {
				"top": "0",
				"bottom": "0"
			},
			"blockGap": "var:preset|spacing|50"
		}
	}
}
