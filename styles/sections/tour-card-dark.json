{
  "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
  "version": 3,
  "title": "Card Dark",
  "slug": "card-dark",
  "blockTypes": [
    "core/group"
  ],
  "description": "Dark ATI styling for reusable tour cards.",
  "styles": {
    "border": {
      "radius": "var:preset|border-radius|100"
    },
    "color": {
      "background": "var:preset|color|primary-500",
      "text": "var:preset|color|base"
    },
    "shadow": "var:preset|shadow|200",
    "spacing": {
      "blockGap": "var:preset|spacing|20"
    },
    "css": "&{overflow:hidden;max-width:30rem;transition:box-shadow 300ms ease;} &:hover{box-shadow:var(--wp--preset--shadow--500)!important;} & :is([aria-label=\"Details\"],[aria-label=\"Tour details\"]){border-top-color:var(--wp--preset--color--brand-500);} & .wp-block-cover,& .wp-block-post-featured-image{overflow:hidden;} & .wp-block-cover .wp-block-cover__image-background,& .wp-block-post-featured-image img{transition:transform 300ms ease;} &:hover .wp-block-cover .wp-block-cover__image-background,&:hover .wp-block-post-featured-image img{transform:scale(1.05);}",
    "elements": {
      "heading": {
        "color": {
          "text": "var:preset|color|base"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|base"
        },
        ":hover": {
          "color": {
            "text": "var:preset|color|base"
          }
        }
      },
      "button": {
        "color": {
          "background": "var:preset|color|brand-500",
          "text": "var:preset|color|base"
        },
        ":hover": {
          "color": {
            "background": "var:preset|color|accent-500",
            "text": "var:preset|color|base"
          }
        },
        "css": "&:focus-visible{outline:2px solid var(--wp--preset--color--brand-500);outline-offset:2px;}"
      },
      "separator": {
        "color": {
          "background": "var:preset|color|brand-500"
        }
      }
    },
    "blocks": {
      "core/post-excerpt": {
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|brand-500"
            },
            ":hover": {
              "color": {
                "text": "var:preset|color|brand-300"
              }
            }
          }
        }
      },
      "core/post-terms": {
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|brand-500"
            },
            ":hover": {
              "color": {
                "text": "var:preset|color|brand-300"
              }
            }
          }
        }
      },
      "core/paragraph": {
        "elements": {
          "link": {
            "color": {
              "text": "var:preset|color|brand-500"
            },
            ":hover": {
              "color": {
                "text": "var:preset|color|brand-300"
              }
            }
          }
        }
      },
      "outermost/icon-block": {
        "color": {
          "text": "var:preset|color|brand-500"
        },
        "css": "& svg{fill:currentColor;}"
      }
    }
  }
}
