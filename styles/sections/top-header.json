{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"title": "Top Header Section",
	"slug": "section-top-header",
	"blockTypes": [
		"core/group"
	],
	"description": "Top header section style",
	"styles": {
		"spacing": {
			"padding": {
				"left": "var:preset|spacing|30",
				"right": "var:preset|spacing|30"
			}
		},
		"blocks": {
			"links": {
				"color": {
					"text": "var:preset|color|base"
				},
				"hover": {
					"color": {
						"text": "var:preset|color|cta-500"
					},
					"textDecoration": "none"
				}
			}
		}
	}
}
