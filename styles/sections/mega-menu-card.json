{
  "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
  "version": 3,
  "title": "ATI Mega Menu Card",
  "slug": "ati-mega-menu-card",
  "blockTypes": [
    "core/group"
  ],
  "description": "ATI styling for linked mega menu teaser cards.",
  "styles": {
    "color": {
      "background": "var:preset|color|primary-500",
      "text": "var:preset|color|base"
    },
    "css": "&{overflow:hidden;text-decoration:none;} &:hover .wp-block-heading,&:hover .wp-block-heading.has-text-color,&:hover .wp-block-heading.has-base-color,&:hover .wp-block-heading a{color:var(--wp--preset--color--brand-500)!important;} &:focus-within .wp-block-heading,&:focus-within .wp-block-heading.has-text-color,&:focus-within .wp-block-heading.has-base-color,&:focus-within .wp-block-heading a{color:var(--wp--preset--color--brand-500)!important;} & .wp-block-image{overflow:hidden;} & .wp-block-image img{transition:transform 300ms ease;} &:hover .wp-block-image img,&:focus-within .wp-block-image img{transform:scale(1.05);}",
    "elements": {
      "heading": {
        "color": {
          "text": "var:preset|color|base"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|base"
        }
      }
    },
    "blocks": {
      "core/image": {
        "border": {
          "radius": "var:preset|border-radius|200"
        }
      },
      "core/heading": {
        "css": "&{transition:color 200ms ease;}",
        "elements": {
          "link": {
            "css": "&{transition:color 200ms ease;}"
          }
        }
      }
    }
  }
}
